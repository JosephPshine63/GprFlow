# Copy to .env and fill in real values. Never commit the real .env file.
# Read automatically by `docker compose` when present in this directory.

# Database
DB_NAME=gprflow
DB_USERNAME=postgres
DB_PASSWORD=postgres

# JWT
JWT_SECRET=change-me-to-a-long-random-secret
JWT_EXPIRATION_MS=86400000

# Frontend URL used for payment/OAuth redirect callbacks (seen by the app container)
FRONTEND_URL=http://localhost:5173

# Base URL the browser uses to reach the backend, i.e. the gateway (baked
# into the frontend container's runtime-config.js at startup)
API_BASE_URL=http://localhost:8080

# SMTP (Gmail app password, not your account password)
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-gmail-app-password

# Stripe
STRIPE_API_KEY=sk_test_xxx

# Razorpay
RAZORPAY_API_KEY=rzp_test_xxx
RAZORPAY_API_SECRET=your-razorpay-secret

# CoinGecko
COINGECKO_API_KEY=your-coingecko-api-key

# Gemini AI
GEMINI_API_KEY=your-gemini-api-key

# Google OAuth2 (optional)
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
