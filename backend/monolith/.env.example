# Copy to .env and fill in real values. Never commit the real .env file.
# For local `mvn spring-boot:run`, load this with: set -a; source .env; set +a

# Database
DB_URL=jdbc:postgresql://localhost:5432/gprflow
DB_USERNAME=postgres
DB_PASSWORD=postgres

# JWT
JWT_SECRET=change-me-to-a-long-random-secret
JWT_EXPIRATION_MS=86400000

# Frontend URL used for payment/OAuth redirect callbacks
FRONTEND_URL=http://localhost:5173

# SMTP (Gmail app password, not your account password)
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-gmail-app-password

# Stripe
STRIPE_API_KEY=sk_test_xxx

# Razorpay
RAZORPAY_API_KEY=rzp_test_xxx
RAZORPAY_API_SECRET=your-razorpay-secret

# Google OAuth2 (optional)
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
