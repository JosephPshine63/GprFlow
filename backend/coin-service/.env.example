# Copy to .env and fill in real values. Never commit the real .env file.
# For local `mvn spring-boot:run`, load this with: set -a; source .env; set +a

# Database (same Postgres instance as the monolith, schema "coin")
DB_URL=jdbc:postgresql://localhost:5432/gprflow?currentSchema=coin
DB_USERNAME=postgres
DB_PASSWORD=postgres

# JWT — must match the monolith's JWT_SECRET so tokens issued there validate here
JWT_SECRET=change-me-to-a-long-random-secret
JWT_EXPIRATION_MS=86400000

# CoinGecko
COINGECKO_API_KEY=your-coingecko-api-key
